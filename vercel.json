{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/lokasi/tangerang",        "destination": "/lokasi/konveksi-seragam-tangerang",          "permanent": true },
    { "source": "/lokasi/tangerang.html",   "destination": "/lokasi/konveksi-seragam-tangerang",          "permanent": true },
    { "source": "/lokasi/tangsel",          "destination": "/lokasi/konveksi-seragam-tangerang-selatan",  "permanent": true },
    { "source": "/lokasi/tangsel.html",     "destination": "/lokasi/konveksi-seragam-tangerang-selatan",  "permanent": true },
    { "source": "/lokasi/jakarta",          "destination": "/lokasi/konveksi-seragam-jakarta",            "permanent": true },
    { "source": "/lokasi/jakarta.html",     "destination": "/lokasi/konveksi-seragam-jakarta",            "permanent": true },
    { "source": "/lokasi/bekasi",           "destination": "/lokasi/konveksi-seragam-bekasi",             "permanent": true },
    { "source": "/lokasi/bekasi.html",      "destination": "/lokasi/konveksi-seragam-bekasi",             "permanent": true },
    { "source": "/lokasi/bogor",            "destination": "/lokasi/konveksi-seragam-bogor",              "permanent": true },
    { "source": "/lokasi/bogor.html",       "destination": "/lokasi/konveksi-seragam-bogor",              "permanent": true },
    { "source": "/lokasi/depok",            "destination": "/lokasi/konveksi-seragam-depok",              "permanent": true },
    { "source": "/lokasi/depok.html",       "destination": "/lokasi/konveksi-seragam-depok",              "permanent": true },
    { "source": "/blog/bikin-seragam-kerja-tangerang.html", "destination": "/blog/bikin-seragam-kerja-tangerang", "permanent": true }
  ],
  "rewrites": [
    { "source": "/blog/bikin-seragam-kerja-tangerang", "destination": "/blog/bikin-seragam-kerja-tangerang.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
